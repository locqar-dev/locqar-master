# LocQar Terminal App — Environment Variables
# Copy this to .env and fill in your values.

# LocQar API base URL
VITE_API_URL=https://api.dev.locqar.com

# API key for /api/locker endpoints (same as LOCKER_API_KEY on the server)
VITE_LOCKER_API_KEY=your-api-key-here

# This kiosk's locker serial number (matches the terminal code in the DB)
VITE_LOCKER_SN=LQ-001

# Local door controller URL (RS-485 bridge, runs on the kiosk hardware)
VITE_DOOR_CONTROLLER_URL=http://127.0.0.1:9090
