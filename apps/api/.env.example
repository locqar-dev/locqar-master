# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# ── CORS (comma-separated origins) ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5176,http://localhost:5177,http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/locqar_dev
DATABASE_URL_TEST=postgresql://user:password@localhost:5432/locqar_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_64_char_random_hex_string_here_xxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_64_char_random_hex_string_here_yyyyyyyyyyyyyyyyyyyyyyy
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=180
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ── Ghana SMS (Arkesel) ───────────────────────────────────────────────────────
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=LocQar

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── MTN MoMo ─────────────────────────────────────────────────────────────────
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_ENVIRONMENT=sandbox

# ── Telecel Cash ─────────────────────────────────────────────────────────────
TELECEL_CASH_API_KEY=
TELECEL_CASH_MERCHANT_ID=

# ── Winnsen Locker Hardware API ───────────────────────────────────────────────
# URL for outbound calls to Winnsen cloud (SetPinCode, GetTerminalInfo, etc.)
WINNSEN_CLOUD_API_BASE=https://cloud.winnsen.com/logistics3/api2
# APIKey provided by Winnsen — sent in every outbound request body
WINNSEN_API_KEY=
# Secret the kiosk sends as x-api-key header when calling POST /api/winnsen/events
WINNSEN_INBOUND_API_KEY=

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
AWS_BUCKET_NAME=
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MAX_FILE_SIZE_MB=10

# ── Real-time ─────────────────────────────────────────────────────────────────
REALTIME_PROVIDER=socketio

# ── Ghana Tax Rates ───────────────────────────────────────────────────────────
SSNIT_EMPLOYEE_RATE=0.055
SSNIT_EMPLOYER_RATE=0.13

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GENERAL=200
RATE_LIMIT_MAX_AUTH=20
RATE_LIMIT_MAX_OTP=5

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Frontend URLs ─────────────────────────────────────────────────────────────
ADMIN_PORTAL_URL=http://localhost:5173
COURIER_APP_URL=http://localhost:5176
CUSTOMER_APP_URL=http://localhost:5177
WEBSITE_URL=http://localhost:3000
