// This schema file was generated by the Local Server Agent
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  phone     String?
  role      String   @default("AGENT") // SUPER_ADMIN, ADMIN, MANAGER, AGENT
  password  String   // Hashed
  lastLogin DateTime?
  isActive  Boolean  @default(true)
  
  // Relations
  auditLogs               AuditLog[]
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  tokenBlacklist          TokenBlacklist[]
  twoFactorAuth           TwoFactorAuth?
  sessions                Session[]
  complianceLogs          ComplianceLog[]
  apiKeys                 ApiKey[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Terminal {
  id           String   @id @default(uuid())
  name         String
  location     String
  city         String?
  region       String?
  status       String   @default("ONLINE") // ONLINE, OFFLINE, MAINTENANCE
  lockers      Locker[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Locker {
  id          String   @id @default(uuid())
  displayId   String   // e.g. "A-01"
  doorNumber  Int
  size        String   // SMALL, MEDIUM, LARGE, XLARGE
  status      String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, MAINTENANCE
  terminalId  String
  terminal    Terminal @relation(fields: [terminalId], references: [id])
  packages    Package[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Package {
  id             String   @id @default(uuid())
  waybill        String   @unique // e.g. "LQ-2024-00001"
  status         String   // PENDING, IN_TRANSIT, DELIVERED_TO_LOCKER, PICKED_UP, EXPIRED
  customerName   String?
  customerPhone  String?
  customerEmail  String?
  pickupCode     String?
  metadata       String? // JSON string for extra data
  
  // Relations
  lockerId       String?
  locker         Locker?  @relation(fields: [lockerId], references: [id])
  auditLogs      AuditLog[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ==================== ENTERPRISE FEATURES ====================

// Audit Logs - Track all system activities for compliance
model AuditLog {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String   // CREATE, UPDATE, DELETE, VIEW, EXPORT, etc.
  entityType    String   // Package, Locker, User, etc.
  entityId      String?  // ID of the entity being audited (e.g. packageId)
  packageId     String?
  package       Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  oldValues     String?  // JSON string of previous values
  newValues     String?  // JSON string of new values
  ipAddress     String?
  userAgent     String?
  status        String   @default("SUCCESS") // SUCCESS, FAILURE
  errorMessage  String?
  createdAt     DateTime @default(now())
}

// Analytics - Track usage metrics and business intelligence
model Analytics {
  id                    String   @id @default(uuid())
  date                  DateTime @default(now()) @db.Date
  packagesDelivered     Int      @default(0)
  packagesPending       Int      @default(0)
  totalRevenue          Float    @default(0)
  averageDeliveryTime   Float    @default(0) // in hours
  lockerUtilization     Float    @default(0) // percentage
  activeUsers           Int      @default(0)
  newUsers              Int      @default(0)
  terminalsOnline       Int      @default(0)
  failedTransactions    Int      @default(0)
  metadata              String?  // JSON for additional metrics
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  @@unique([date]) // One record per day
}

// Notifications - Real-time and stored notifications
model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // DELIVERY, PAYMENT, SECURITY, PROMOTION, SYSTEM
  title       String
  message     String
  data        String?  // JSON payload for action data
  read        Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())
  expiresAt   DateTime? // Auto-delete after this date
  @@index([userId, read])
}

// Notification Preferences - User control over notifications
model NotificationPreference {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications    Boolean @default(true)
  smsNotifications      Boolean @default(true)
  pushNotifications     Boolean @default(true)
  deliveryAlerts        Boolean @default(true)
  paymentAlerts         Boolean @default(true)
  securityAlerts        Boolean @default(true)
  promotionalEmails     Boolean @default(false)
  weeklyDigest          Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Token Blacklist - For logout and token invalidation
model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([expiresAt])
}

// Two-Factor Authentication
model TwoFactorAuth {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled     Boolean  @default(false)
  secret      String?  // TOTP secret
  backupCodes String?  // JSON array of backup codes
  method      String   @default("AUTHENTICATOR") // AUTHENTICATOR, SMS, EMAIL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// User Sessions - Track active sessions
model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName   String?
  ipAddress    String?
  userAgent    String?
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  @@index([userId, expiresAt])
}

// Compliance Logs - GDPR, privacy, and regulatory compliance
model ComplianceLog {
  id            String   @id @default(uuid())
  type          String   // DATA_ACCESS, DATA_EXPORT, CONSENT_CHANGE, ACCOUNT_DELETE
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  description   String
  status        String   @default("COMPLETED") // COMPLETED, PENDING, FAILED
  consentFlag   String?  // Type of consent given/revoked
  evidence      String?  // JSON data proving compliance
  createdAt     DateTime @default(now())
}

// API Keys - For programmatic access
model ApiKey {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyHash     String   @unique // Hashed version of the actual key
  name        String
  permissions String   // JSON array of permissions
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@index([userId, active])
}
