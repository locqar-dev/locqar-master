# LocQar Door Controller — Environment Configuration
# Copy to .env and adjust for your locker hardware

# Serial port path to the RS-485 bus (check with `ls /dev/ttyS* /dev/ttyUSB*`)
# Common paths: /dev/ttyS1 (built-in UART), /dev/ttyUSB0 (USB-to-RS485 adapter)
SERIAL_PORT=/dev/ttyS1

# Baud rate — Winnsen lock boards use 9600
SERIAL_BAUD=9600

# Station offset — if first board's DIP switch is set to station 2, set this to 1
# Door 1 maps to station (1 + offset), door 17 maps to station (2 + offset), etc.
STATION_OFFSET=1

# HTTP port for the local API
HTTP_PORT=9090

# Set to "true" for development without physical hardware
SIMULATE=false

# Optional shared secret — terminal-app sends this in x-api-key header
API_KEY=
